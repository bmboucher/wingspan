      "name": "batched_collect.py",
      "filePath": "src/wingspan/training/batched_collect.py",
      "summary": "Implements batched inference self-play collection: a _BatchInferenceServer accumulates per-step inference requests from concurrent game threads and processes them as a single GPU batch, amortizing inference overhead.",
      "tags": ["training", "data-pipeline", "service"],
      "complexity": "complex",
      "languageNotes": "Uses threading (Condition + Events) to synchronize game worker threads with the single inference server thread, forming a producer/consumer barrier."
    },
