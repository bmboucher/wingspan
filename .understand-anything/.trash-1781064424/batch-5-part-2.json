    {
      "id": "file:src/wingspan/training/mp_collect.py",
      "type": "file",
      "name": "mp_collect.py",
      "filePath": "src/wingspan/training/mp_collect.py",
      "summary": "Multiprocess game collection engine: a ProcessPoolExecutor-backed ProcessCollector spawns worker processes for self-play, setup-phase games, and evaluation, broadcasting updated weights via atomic temp-file saves.",
      "tags": ["training", "data-pipeline", "service"],
      "complexity": "complex",
      "languageNotes": "Workers are initialized once per process (global state pattern) and reload weights lazily via version checks on the shared file, avoiding redundant weight transfers across games."
    },
