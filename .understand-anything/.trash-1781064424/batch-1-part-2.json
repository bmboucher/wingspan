      "id": "file:src/wingspan/decisions.py",
      "type": "file",
      "name": "decisions.py",
      "filePath": "src/wingspan/decisions.py",
      "summary": "Defines the complete Decision/Choice type hierarchy used across the game engine: 41 Choice subclasses and corresponding Decision[C] containers covering every agent decision point from setup through end-of-round.",
      "tags": ["data-model", "type-definition", "decisions", "agent"],
      "complexity": "complex",
      "languageNotes": "ALL_DECISION_CLASSES ordering is stable and append-only; SetupDecision must remain last. Generic Decision[C: Choice] with Protocol-based Agent is the core extensibility contract."
    },
