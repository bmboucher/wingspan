{
  "nodes": [
    {
      "id": "file:src/wingspan/training/config.py",
      "type": "file",
      "name": "config.py",
      "filePath": "src/wingspan/training/config.py",
      "summary": "Defines TrainConfig, the authoritative Pydantic model for all training hyperparameters covering the main network, setup model, ELO evaluation, encoding dims, and architecture key derivation.",
      "tags": ["config", "data-model", "training", "entry-point"],
      "complexity": "complex",
      "languageNotes": "TrainConfig is the single source of truth for architecture topology — its arch/setup_arch properties build ModelArchitecture/SetupArchitecture from the config fields, and architecture_key identifies encoding-shape changes for checkpoint compat."
    },
    {
      "id": "file:src/wingspan/training/configure/__init__.py",
      "type": "file",
      "name": "__init__.py",
      "filePath": "src/wingspan/training/configure/__init__.py",
      "summary": "Package barrel for the training configurator sub-package, re-exporting from controller, fields, runs, screen, and state modules.",
      "tags": ["entry-point", "barrel", "training"],
      "complexity": "simple"
    },
    {
      "id": "file:src/wingspan/training/configure/controller.py",
      "type": "file",
      "name": "controller.py",
      "filePath": "src/wingspan/training/configure/controller.py",
      "summary": "Implements the input-handling controller for the interactive training configurator, dispatching keyboard events to navigate fields, edit values, confirm actions, and launch/archive training runs.",
      "tags": ["controller", "training", "interactive", "event-handler"],
      "complexity": "complex"
    },
    {
      "id": "file:src/wingspan/training/configure/fields.py",
      "type": "file",
      "name": "fields.py",
      "filePath": "src/wingspan/training/configure/fields.py",
      "summary": "Defines the FieldSpec type hierarchy (IntField, FloatField, ChoiceField, LayersField, etc.) and all TrainConfig field descriptors, plus read/format/commit/nudge operations for the configurator UI.",
      "tags": ["config", "data-model", "training", "ui"],
      "complexity": "complex",
      "languageNotes": "Defines ~1100 lines of field metadata for every TrainConfig attribute, including visibility predicates (visible_when), grouping, help text, and step sizes — the single source of truth for the config form layout."
    },
    {
      "id": "file:src/wingspan/training/configure/keys.py",
      "type": "file",
      "name": "keys.py",
      "filePath": "src/wingspan/training/configure/keys.py",
      "summary": "Cross-platform keyboard input abstraction providing KeyReader (context manager), KeyEvent/KeyKind models, and decode helpers for Windows msvcrt and POSIX termios input.",
      "tags": ["utility", "ui", "platform", "input-handling"],
      "complexity": "moderate"
    },
    {
